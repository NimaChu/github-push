# .gitignore for GitHub Upload Skill

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
ENV/
env/
.venv

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
# .DS_Store - disabled for test upload
Thumbs.db

# Jupyter Notebook
.ipynb_checkpoints

# Environment variables
.env
.env.local
.env.*.local

# pytest
.pytest_cache/
.coverage
htmlcov/
.tox/

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre Type Checker
.pyre/

# pytype static type analyzer
.pytype/

# Cython debug symbol
cython_debug/

# Temp files
*.tmp
*.temp
*.log

# Test images (if any)
test_images/
*.jpeg
*.jpg
*.png
*.gif

# Large files (GitHub limit)
*.zip
*.tar
*.tar.gz
*.dmg
*.exe
*.dll
*.so
*.dylib

# Sensitive files
.id_rsa
.id_rsa.pub
*.pem
*.key
config.json
secrets.yaml
*.secret

# GitHub specific
.git
